<%= form_with model: @card, local: true, html: { class: "card-form" } do |f| %>
  <div class="form-group">
    <%= f.label :name %>
    <%= f.text_field :name, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :set %>
    <%= f.text_field :set, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :quantity %>
    <%= f.number_field :quantity, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :photo %>
    <%= f.text_field :photo_url, class: "form-control" %>
  </div>

  <%= f.submit "Add Card", class: "submit-button" %>
<% end %>
